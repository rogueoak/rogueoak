# Public site configuration. No secrets belong in this file or in git.
# Copy to .env.local for local development (.env* is git-ignored except this file).

# Canonical site origin, used for absolute URLs / metadata.
SITE_URL=https://rogueoak.com

# PostHog analytics. These are NEXT_PUBLIC_ and are INLINED at build time (not
# read at runtime). The key is PostHog's *publishable* project key (the phc_
# client token) - it ships in the browser bundle by design, so it is not a secret
# and src/lib/analytics.ts carries a committed default. Set these only to target a
# different PostHog project; a build without them uses the default. Analytics only
# captures from a deployed, non-local production build (see src/lib/analytics-env.js).
#   NEXT_PUBLIC_POSTHOG_KEY  - publishable phc_ project key (US Cloud).
#   NEXT_PUBLIC_POSTHOG_HOST - client ingest host; defaults to the /ingest proxy.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=/ingest

# Constant Contact - the subscribe endpoint (spec 0008). These are SERVER-ONLY
# secrets, read at runtime by app/v1/subscribe only; they are NEVER inlined into
# the client bundle. In production they live in a host-side, git-ignored
# deploy/docker/.env.site (see deploy/README.md), not here. Unset => the subscribe
# route fails closed (a generic 500) while the rest of the site works. An email
# ending in @rogueoak.com is a test address the route accepts without calling
# Constant Contact, so the form UX can be exercised without these set.
#   CTCT_CLIENT_ID     - Constant Contact app client id (public client, no secret).
#   CTCT_REFRESH_TOKEN - long-lived, non-rotating refresh token (secret).
#   CTCT_LIST_ID       - id of the "Rogue Oak" contact list.
CTCT_CLIENT_ID=
CTCT_REFRESH_TOKEN=
CTCT_LIST_ID=
