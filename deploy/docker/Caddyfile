# Caddy routes by hostname and provisions/renews Let's Encrypt certs automatically
# (needs ports 80/443 reachable and DNS pointing at this server first). HTTP is
# redirected to HTTPS automatically. No ACME email is set on purpose: a personal
# address must never live in a tracked file.

# Apex: serve the site, proxying to the standalone Next server on the edge network.
rogueoak.com {
	encode zstd gzip
	# HSTS belongs at the TLS terminator. The app sets the other security headers
	# (X-Frame-Options, X-Content-Type-Options, ...) in next.config.ts.
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"
	reverse_proxy site:3000
}

# www -> apex. Caddy still issues a cert for www so the redirect is served over HTTPS.
www.rogueoak.com {
	redir https://rogueoak.com{uri} permanent
}
